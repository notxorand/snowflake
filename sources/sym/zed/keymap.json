// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
      // "ctrl-t": "terminal_panel::ToggleFocus",
      "ctrl-n": "workspace::ToggleRightDock",
      // "shift-ctrl-e": "project_panel::ToggleFocus",
      "ctrl-e": "project_panel::ToggleFocus",
      "alt-z": ["app_menu::OpenApplicationMenu", "Zed"],
      "alt-f": ["app_menu::OpenApplicationMenu", "File"],
      "alt-e": ["app_menu::OpenApplicationMenu", "Edit"],
      "alt-s": ["app_menu::OpenApplicationMenu", "Selection"],
      "alt-v": ["app_menu::OpenApplicationMenu", "View"],
      "alt-g": ["app_menu::OpenApplicationMenu", "Go"],
      "alt-w": ["app_menu::OpenApplicationMenu", "Window"],
      "alt-h": "terminal_panel::Toggle",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      // "j k": ["workspace::SendKeystrokes", "escape"]
      "ctrl-n": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "alt-h": "workspace::ToggleBottomDock",
      "ctrl-t": "workspace::NewTerminal",
      "ctrl-w k": "editor::ToggleFocus",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "space": "command_palette::Toggle", // leader key
      "space e": "project_panel::ToggleFocus",
      "space /": "editor::ToggleComments",
      "space x": "pane::CloseActiveItem",
      "space b": "workspace::NewFile",
      "space f a": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space g t": "git_panel::Toggle",
      "g c": "editor::ToggleComments",
      "alt-h": "terminal_panel::Toggle",
      ";": "command_palette::Toggle",
      "tab": "tab_switcher::ToggleAll",
      "shift-tab": "tab_switcher::ToggleAll",
    },
  },
  {
    "context": "(VimControl && VimCount)",
    "bindings": {
      ";": "vim::CountCommand",
      "tab": "tab_switcher::ToggleAll",
      "shift-tab": "tab_switcher::ToggleAll",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      ";": "vim::VisualCommand",
      "tab": "tab_switcher::ToggleAll",
      "shift-tab": "tab_switcher::ToggleAll",
    },
  },
  {
    "context": "!Editor",
    "bindings": {
      "ctrl-n": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "(!Editor && !Terminal)",
    "bindings": {
      ";": "command_palette::Toggle",
      "space": "command_palette::Toggle", // leader key
      "space x": "pane::CloseActiveItem",
      "space e": "project_panel::ToggleFocus",
      "space /": "editor::ToggleComments",
      "space x": "pane::CloseActiveItem",
      "space b": "workspace::NewFile",
      "space f a": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space g t": "git_panel::Toggle",
    },
  },
  {
    "context": "(Editor && showing_completions)",
    "bindings": {
      "tab": "editor::ContextMenuNext",
    },
  },
]
